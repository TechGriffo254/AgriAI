APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# -----------------------------
# AI / LLM Configuration
# -----------------------------
LLM_PROVIDER=groq
LLM_CHAT_PROVIDER=groq
LLM_VISION_PROVIDER=gemini

GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_TOKENS=8192
GROQ_TEMPERATURE=0.7

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_VISION_MODEL=gemini-2.0-flash
GEMINI_MAX_TOKENS=8192
GEMINI_TEMPERATURE=0.7

OPENAI_API_KEY=
OPENAI_ORGANIZATION=
OPENAI_MODEL=gpt-4o
OPENAI_VISION_MODEL=gpt-4o
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.7

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_VISION_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MAX_TOKENS=4096
ANTHROPIC_TEMPERATURE=0.7

LLM_RATE_LIMIT_PER_MINUTE=20
LLM_RATE_LIMIT_PER_DAY=500
LLM_TOKENS_PER_DAY=100000
LLM_CACHE_ENABLED=true
LLM_CACHE_TTL=3600

FEATURE_CROP_ADVISOR=true
FEATURE_PEST_DIAGNOSIS=true
FEATURE_WEATHER_INSIGHTS=true
FEATURE_MARKET_INTELLIGENCE=true
FEATURE_SOIL_ANALYSIS=true
FEATURE_IRRIGATION_ADVISOR=true
FEATURE_CHAT_ASSISTANT=true
FEATURE_IMAGE_ANALYSIS=true

# -----------------------------
# Weather Configuration
# -----------------------------
WEATHER_PROVIDER=openweathermap
OPENWEATHERMAP_API_KEY=
WEATHERAPI_KEY=
WEATHER_UNITS=metric
WEATHER_CACHE_ENABLED=true
WEATHER_CURRENT_TTL=1800
WEATHER_FORECAST_TTL=3600
WEATHER_HISTORICAL_TTL=86400
WEATHER_FORECAST_DAYS=7
WEATHER_UPDATE_INTERVAL=3600

FROST_WARNING_TEMP=2
HEAT_WARNING_TEMP=35
HEAVY_RAIN_THRESHOLD=50
DROUGHT_ALERT_DAYS=7
WIND_WARNING_SPEED=50

VITE_APP_NAME="${APP_NAME}"
